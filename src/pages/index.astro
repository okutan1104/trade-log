---
import Layout from '../layouts/Layout.astro';
const posts = await Astro.glob('./posts/*.md');
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<Layout title="トレード記録一覧">
    <h1>最新のトレード記録</h1>
    <div class="post-list">
        {sortedPosts.map(post => (
            <a href={post.url} class="post-card">
                {post.frontmatter.thumbnail && (
                    <div class="thumbnail-wrapper">
                        <img src={post.frontmatter.thumbnail} alt="サムネイル" class="post-thumbnail" />
                    </div>
                )}
                <div class="post-content">
                    <div class="meta">
                        <span class="date">{post.frontmatter.date}</span>
                        <span class={`badge ${post.frontmatter.result}`}>{post.frontmatter.pips}</span>
                    </div>
                    <h2 class="post-title">{post.frontmatter.title}</h2>
                </div>
            </a>
        ))}
    </div>
</Layout>

<style>
    .post-list { display: flex; flex-direction: column; gap: 20px; }
    .post-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 15px;
        text-decoration: none;
        color: inherit;
        transition: transform 0.15s, border-color 0.15s;
        display: flex;
        gap: 20px;
        align-items: center;
    }
    .post-card:hover { transform: translateY(-2px); border-color: var(--accent); }
    
    /* サムネイルの枠制限 */
    .thumbnail-wrapper {
        width: 180px;
        height: 110px;
        flex-shrink: 0;
        overflow: hidden;
        border-radius: 6px;
        border: 1px solid var(--border);
    }
    .post-thumbnail {
        width: 100%;
        height: 100%;
        object-fit: cover;
        margin: 0; /* 共通スタイルのマージンをリセット */
    }
    
    .post-content { flex-grow: 1; }
    .post-title { border: none; padding: 0; margin: 10px 0 0 0; font-size: 1.2rem; }
    .meta { display: flex; gap: 15px; align-items: center; font-size: 0.9rem; color: var(--text-muted); }
    .badge { padding: 3px 10px; border-radius: 4px; font-weight: bold; color: #fff; font-size: 0.85rem; }
    .badge.win { background-color: #10b981; }
    .badge.loss { background-color: #ef4444; }

    /* スマホ表示の時は縦並びにする */
    @media (max-width: 600px) {
        .post-card { flex-direction: column; align-items: flex-start; gap: 15px; }
        .thumbnail-wrapper { width: 100%; height: 160px; }
    }
</style>