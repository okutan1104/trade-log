---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | GOLD TRADING LOG</title>
</head>
<body>
    <header class="navbar">
        <div class="container">
            <a href="/" class="logo">📈 GOLD TRADING LOG</a>
        </div>
    </header>
    <main class="container">
        <slot />
    </main>
</body>
</html>

<style is:global>
    :root {
        --bg-color: #0f172a;
        --card-bg: #1e293b;
        --text-color: #f8fafc;
        --text-muted: #94a3b8;
        --accent: #ea580c;
        --border: #334155;
    }
    body {
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        margin: 0;
        padding: 0;
        line-height: 1.6;
    }
    .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
    }
    .navbar {
        background-color: #020617;
        border-bottom: 1px solid var(--border);
        padding: 10px 0;
    }
    .logo {
        color: #fff;
        font-size: 1.4rem;
        text-decoration: none;
        font-weight: bold;
        letter-spacing: 0.5px;
    }
    h1 { color: #fff; font-size: 1.8rem; margin-bottom: 25px; }
    h2 { border-left: 4px solid var(--accent); padding-left: 12px; font-size: 1.3rem; margin-top: 35px; color: #fff; }
    p { color: #cbd5e1; }
    img { max-width: 100%; height: auto; border-radius: 8px; border: 1px solid var(--border); margin: 20px 0; display: block; }
    ul { padding-left: 20px; color: #cbd5e1; }
    li { margin-bottom: 8px; }
</style>